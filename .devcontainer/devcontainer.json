{
  "name": "Flowpunk Full Stack",
  "dockerComposeFile": "docker-compose.yml",
  "service": "workspace",
  "workspaceFolder": "/workspace",
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  },
  "postCreateCommand": "sudo chown -R node:node /workspace/node_modules && pnpm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "mikestead.dotenv",
        "orta.vscode-jest"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "forwardPorts": [8787, 8788, 8789, 8790, 8800, 8801, 8802, 8803, 8850, 8900, 3000, 5432, 8108],
  "portsAttributes": {
    "8787": {
      "label": "Gateway",
      "onAutoForward": "notify"
    },
    "8788": {
      "label": "People Service (indie)",
      "onAutoForward": "silent"
    },
    "8789": {
      "label": "Pipeline Service (indie)",
      "onAutoForward": "silent"
    },
    "8790": {
      "label": "Automations Service (indie)",
      "onAutoForward": "silent"
    },
    "8800": {
      "label": "Tenant Router shard 1 (managed)",
      "onAutoForward": "silent"
    },
    "8801": {
      "label": "Tenant Router shard 2 (managed)",
      "onAutoForward": "silent"
    },
    "8802": {
      "label": "Tenant Router shard 3 (managed)",
      "onAutoForward": "silent"
    },
    "8803": {
      "label": "Tenant Router shard 4 (managed)",
      "onAutoForward": "silent"
    },
    "8850": {
      "label": "Provisioner (managed)",
      "onAutoForward": "silent"
    },
    "8900": {
      "label": "Tenants (managed)",
      "onAutoForward": "silent"
    },
    "3000": {
      "label": "Dashboard",
      "onAutoForward": "notify"
    },
    "5432": {
      "label": "PostgreSQL",
      "onAutoForward": "silent"
    },
    "8108": {
      "label": "Typesense",
      "onAutoForward": "silent"
    }
  },
  "remoteEnv": {
    "DATABASE_URL": "postgres://flowpunk:flowpunk_dev@postgres:5432/flowpunk_dev",
    "TYPESENSE_HOST": "typesense",
    "TYPESENSE_PORT": "8108",
    "TYPESENSE_API_KEY": "flowpunk_dev_key"
  }
}
